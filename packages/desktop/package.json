{
  "name": "@codex-search/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Search all your OpenAI Codex desktop app chat sessions, including archived ones",
  "author": "LookAtWhatAiCanDo",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "dist": "electron-builder",
