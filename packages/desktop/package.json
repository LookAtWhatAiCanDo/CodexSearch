  },
  "devDependencies": {
    "@types/node": "^22",
    "electron": "33.4.11",
    "electron-builder": "^25",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
